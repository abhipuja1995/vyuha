# Database
DATABASE_URL=postgresql+asyncpg://vyuha:vyuha@localhost:5432/vyuha

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM Judges
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key

# TTS Providers
SARVAM_API_KEY=your_sarvam_api_key
AZURE_SPEECH_KEY=your_azure_speech_key
AZURE_SPEECH_REGION=eastus
ELEVENLABS_API_KEY=your_elevenlabs_api_key  # fallback

# STT
DEEPGRAM_API_KEY=your_deepgram_api_key

# Voice Agent Connection (VAUT)
VAUT_WEBSOCKET_URL=ws://localhost:8765

# Scoring thresholds
EVA_A_PASS_THRESHOLD=0.85
REGRESSION_PASS_RATE=0.97
LATENCY_P95_THRESHOLD_MS=800
HALLUCINATION_RATE_THRESHOLD=0.02

# Judge model configuration (override per metric in judge_config.json)
DEFAULT_JUDGE_MODEL=claude-sonnet-4-6
FALLBACK_JUDGE_MODEL=gpt-4o

# Security — recommended for production
# Set VYUHA_API_KEY to enable X-API-Key auth on all endpoints
VYUHA_API_KEY=
# Comma-separated allowed CORS origins (leave empty to allow all — not for prod)
API_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8501
